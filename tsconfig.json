{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@yify/domain": [
        "./domain/index.ts"
      ],
      "@yify/data": [
        "./data/index.ts"
      ],
      "@yify/presentation": [
        "./presentation/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
