{
  "name": "yify",
  "main": "expo-router/entry",
  "version": "1.0.6",
  "versionCode": 31,
  "private": true,
  "scripts": {
    "start": "NODE_OPTIONS=--max-old-space-size=8192 CI=false expo start",
    "android": "NODE_OPTIONS=--max-old-space-size=8192 expo run:android",
    "android:debug": "bash scripts/run-android-debug.sh",
    "android:release": "bash scripts/run-android-release.sh",
    "ios": "NODE_OPTIONS=--max-old-space-size=8192 CI=false DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer expo run:ios",
    "ios:start": "NODE_OPTIONS=--max-old-space-size=8192 CI=false DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer expo start --ios",
    "web": "NODE_OPTIONS=--max-old-space-size=8192 CI=false expo start --web",
    "export:web": "NODE_OPTIONS=--max-old-space-size=8192 EXPO_WEB_BASE_URL=/yify expo export --platform web",
    "export:desktop": "NODE_OPTIONS=--max-old-space-size=8192 EXPO_WEB_BASE_URL='' expo export --platform web",
    "desktop": "yarn export:desktop && electron desktop/main.js",
    "desktop:dev": "electron desktop/main.js",
    "desktop:build": "yarn export:desktop && electron-builder --mac",
    "desktop:build:all": "yarn export:desktop && electron-builder --mac --win --linux",
    "lint": "expo lint app data domain presentation",
    "prebuild": "expo prebuild",
    "postinstall": "patch-package",
    "revopush": "cd revopush && yarn gui"
  },
  "dependencies": {
    "@expo-google-fonts/fraunces": "0.4.1",
    "@expo-google-fonts/hanken-grotesk": "0.4.3",
    "@expo/log-box": "56.0.13",
    "@expo/metro-runtime": "56.0.15",
    "@expo/ui": "56.0.18",
    "@expo/vector-icons": "15.0.2",
    "@react-native-firebase/app": "24.1.1",
    "@react-native-firebase/remote-config": "24.1.1",
    "@revopush/expo-code-push-plugin": "1.1.0",
    "@revopush/react-native-code-push": "2.6.0",
    "expo": "57",
    "expo-background-task": "56.0.19",
    "expo-blur": "57.0.0",
    "expo-build-properties": "57.0.3",
    "expo-constants": "56.0.20",
    "expo-device-corner-radius": "0.1.1",
    "expo-font": "56.0.7",
    "expo-glass-effect": "57.0.0",
    "expo-image": "57.0.0",
    "expo-linking": "56.0.15",
    "expo-notifications": "57.0.3",
    "expo-router": "56.2.11",
    "expo-splash-screen": "57.0.2",
    "expo-status-bar": "57.0.0",
    "expo-symbols": "57.0.0",
    "expo-system-ui": "57.0.0",
    "expo-task-manager": "57.0.1",
    "expo-web-browser": "57.0.0",
    "firebase": "12.16.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "2.31.1",
    "react-native-mmkv": "4.3.2",
    "react-native-nitro-modules": "0.36.1",
    "react-native-reanimated": "4.3.2",
    "react-native-safe-area-context": "5.7.0",
