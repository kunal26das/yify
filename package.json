{
  "name": "yify",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "domain",
    "data",
    "presentation"
  ],
  "scripts": {
    "start": "NODE_OPTIONS=--max-old-space-size=8192 CI=false expo start",
    "android": "NODE_OPTIONS=--max-old-space-size=8192 expo run:android",
    "android:debug": "bash scripts/run-android-debug.sh",
    "android:release": "bash scripts/run-android-release.sh",
    "ios": "NODE_OPTIONS=--max-old-space-size=8192 CI=false DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer expo run:ios",
    "ios:start": "NODE_OPTIONS=--max-old-space-size=8192 CI=false DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer expo start --ios",
    "web": "NODE_OPTIONS=--max-old-space-size=8192 CI=false expo start --web",
    "lint": "expo lint",
    "prebuild": "expo prebuild"
  },
  "dependencies": {
    "@yify/domain": "*",
    "@yify/data": "*",
    "@yify/presentation": "*",
    "@expo/log-box": "56.0.12",
    "@expo/metro-runtime": "56.0.14",
    "expo": "56.0.3",
    "expo-font": "56.0.5",
    "expo-linking": "56.0.11",
    "expo-router": "56.2.5",
    "expo-splash-screen": "56.0.10",
    "expo-status-bar": "56.0.4",
    "expo-system-ui": "56.0.5",
    "expo-web-browser": "56.0.5",
    "firebase": "12.14.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "3.0.0",
    "react-native-reanimated": "4.4.1",
    "react-native-safe-area-context": "5.8.0",
    "react-native-screens": "4.25.1",
    "react-native-web": "0.21.2",
    "react-native-worklets": "0.9.2"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "eslint": "9.39.3",
    "eslint-config-expo": "56.0.4",
    "eslint-import-resolver-typescript": "3.10.1",
    "typescript": "6.0.3"
  }
}
