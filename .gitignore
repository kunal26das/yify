# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/.idea/

# Android (native folder is tracked — ignore build output & local config)
/android/**/build/
/android/**/.gradle/
/android/**/.cxx/
/android/**/.idea/
/android/**/*.iml
/android/**/*.hprof
/android/local.properties
/android/app/src/main/java/inline/
/android/**/*.jsbundle
